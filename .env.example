# GitHub Container Registry (GHCR)
REGISTRY=ghcr.io
GITHUB_OWNER=yourusername
IMAGE_TAG=latest
GHCR_TOKEN=your-github-token

# Application
APP_DOMAIN=localhost:3000
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=your-secret-key-change-me-in-production
APP_CRYPT_KEY=your-encryption-key-change-me

# Bot
BOT_TOKEN=your-bot-token-from-botfather
BOT_SECRET_TOKEN=your-secret-token-for-webhooks
BOT_SUPPORT_USERNAME=support_username
BOT_MINI_APP=true

# RemnaWave API
REMNAWAVE_HOST=api.remnawave.com
REMNAWAVE_PORT=443
REMNAWAVE_TOKEN=your-remnawave-token
REMNAWAVE_WEBHOOK_SECRET=your-remnawave-webhook-secret
REMNAWAVE_USE_SSL=true

# Database
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=d3mvpn
DATABASE_USER=d3mvpn
DATABASE_PASSWORD=change-me-in-production
DATABASE_ECHO=false
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=change-me-in-production

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
